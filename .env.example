# ============================================================
# 계약똑똑 (contalktok) 환경변수 예시
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 채우세요.
#   cp .env.example .env
# ============================================================

# ─────────────────────────────────────────
# 앱 기본 설정
# ─────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0

# ─────────────────────────────────────────
# Database (PostgreSQL)
# docker-compose: postgres 서비스 호스트명 사용
# 로컬 직접 실행 시: localhost
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/contalktok
POSTGRES_PASSWORD=password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─────────────────────────────────────────
# JWT 인증
# SECRET_KEY: 최소 32자 이상의 무작위 문자열 (프로덕션에서 반드시 변경)
# 생성 예시: openssl rand -hex 32
# ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=contalktok-contracts

# ─────────────────────────────────────────
# AI — OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=
# RAG 법령 근거 생성 및 Vision OCR에 사용하는 모델 (미설정 시 코드 기본값 gpt-5.4)
OPENAI_MODEL=gpt-5.4

# ─────────────────────────────────────────
# AI — Google Cloud Vision (OCR)
# JSON 키 파일 경로 (컨테이너 내부 경로)
# ─────────────────────────────────────────
GOOGLE_CLOUD_CREDENTIALS_PATH=/app/secrets/google-credentials.json

# ─────────────────────────────────────────
# ChromaDB (벡터 DB)
# ─────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=lease_law

# ─────────────────────────────────────────
# 소셜 로그인 — 카카오
# https://developers.kakao.com 에서 발급
# ─────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─────────────────────────────────────────
# 소셜 로그인 — 구글
# https://console.cloud.google.com 에서 발급
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────
# 포트원 (결제)
# https://portone.io 에서 발급 (v1 REST API)
# ─────────────────────────────────────────
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=
PORTONE_PG_PROVIDER=html5_inicis
PORTONE_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# 가격 설정 (KRW, 원 단위)
# ─────────────────────────────────────────
PRICE_SINGLE=5000
PRICE_PASS_3MONTH=19900

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://contalktok.kr

# ─────────────────────────────────────────
# 프론트엔드 (Vite)
# ─────────────────────────────────────────
VITE_API_URL=http://localhost:8000
