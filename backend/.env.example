# ===========================
# 계약똑똑 Backend Environment Variables
# ===========================

# App
APP_ENV=development
APP_VERSION=1.0.0
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/contalktok
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=contalktok-contracts

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=lease_law

# Portone V2 (포트원 V2 — api.portone.io)
PORTONE_V2_API_SECRET=your-portone-v2-api-secret
PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PORTONE_PG_PROVIDER=html5_inicis

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Pricing (in KRW)
PRICE_SINGLE=2900
PRICE_PASS_1MONTH=9900
PRICE_PASS_3MONTH=19900

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://contalktok.kr
